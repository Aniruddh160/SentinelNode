<script>
// SCREEN SWITCH
function goToChat() {
  document.getElementById("home-screen").classList.add("hidden");
  document.getElementById("chat-screen").classList.remove("hidden");
}

// INPUT TOGGLES
function showLocalInput() {
  document.getElementById("local-input").classList.remove("hidden");
  document.getElementById("repo-input").classList.add("hidden");
}

function showRepoInput() {
  document.getElementById("repo-input").classList.remove("hidden");
  document.getElementById("local-input").classList.add("hidden");
}

// INDEX LOCAL
async function indexLocal() {
  const path = document.getElementById("local-path").value;

  await fetch("/index-folder", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({ path })
  });

  document.getElementById("context-info").innerText = path;

  goToChat();
  setTimeout(loadGraph, 1000);
}

// INDEX REPO
async function indexRepo() {
  const url = document.getElementById("repo-url").value;

  await fetch("/clone-repo", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({ repo_url: url })
  });

  document.getElementById("context-info").innerText = url;

  goToChat();
  setTimeout(loadGraph, 1000);
}

// CHAT
const input = document.getElementById("user-input");
const chatInner = document.getElementById("chat-inner");

function addMessage(text, sender="user") {
  const div = document.createElement("div");
  div.className = sender === "user" ? "flex justify-end" : "flex justify-start";

  div.innerHTML = `
    <div class="${sender === "user" ? "bg-blue-600" : "bg-gray-700"} 
      px-4 py-2 rounded-md max-w-[70%] whitespace-pre-wrap">
      ${text}
    </div>
  `;

  chatInner.appendChild(div);
}

input.addEventListener("keydown", async (e) => {
  if (e.key === "Enter") {
    const question = input.value.trim();
    if (!question) return;

    addMessage(question, "user");
    input.value = "";

    const res = await fetch("/query", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({ question })
    });

    const data = await res.json();

    addMessage(data.answer || "No response", "ai");
  }
});

